CONFIG_AMBYTE_WIFI_SSID="__UNPROVISIONED__"
CONFIG_AMBYTE_WIFI_PASSWORD="__UNPROVISIONED__"
# CONFIG_ESP_CONSOLE_UART_DEFAULT is not set
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
# CONFIG_ESP_CONSOLE_SECONDARY_USB_SERIAL_JTAG is not set
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
# CONFIG_ESPTOOLPY_FLASHSIZE_4MB is not set
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_ESPTOOLPY_FLASHSIZE_DETECT=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
# CONFIG_PARTITION_TABLE_SINGLE_APP is not set
# OTA Stage 1: dual-OTA partition table (ota_0/ota_1/otadata) needs rollback so a
# bad self-OTA image (booted PENDING_VERIFY) reverts unless the new app calls
# esp_ota_mark_app_valid_cancel_rollback() — wired in Stage 3, gated on MQTT
# reconnect. Harmless for esptool-flashed apps (they boot VALID, never roll back).
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y
CONFIG_MQTT_PROTOCOL_5=y
# CONFIG_MQTT_PROTOCOL_311 is not set
CONFIG_ESP_TASK_WDT_PANIC=y
CONFIG_ESP_COREDUMP_ENABLE_TO_FLASH=y
CONFIG_HEAP_POISONING_LIGHT=y
CONFIG_COMPILER_STACK_CHECK_MODE_NORM=y
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
# Provisioning is delivered via host-side NVS pre-population (tools/extra_script.py),
# so the Bluetooth stack is left out of the build entirely.
# CONFIG_BT_ENABLED is not set
# FAT long filename support (required for SQLite DB file)
# CONFIG_FATFS_LFN_NONE is not set
CONFIG_FATFS_LFN_HEAP=y
CONFIG_FATFS_MAX_LFN=255
# TLS inbound record buffer max. Was lowered to 8 KiB to let MQTT reconnect on a
# fragmented heap (a 16 KiB contiguous block was unobtainable mid-run -> mbedtls
# ALLOC_FAILED). RESTORED to 16 KiB for OTA: S3/Fastly (GitHub release CDN) stream
# the firmware body in full-size 16 KiB TLS records, and with DYNAMIC_BUFFER on, an
# incoming record larger than this cap fails with -0x7100 (BAD_INPUT_DATA) on the
# first data read. Safe to raise BECAUSE DYNAMIC_BUFFER makes this a *transient
# per-record ceiling*, not a buffer held for the connection's life: MQTT's small
# records still alloc small, only OTA's large records use the 16 KiB headroom. OUT
# stays 4 KiB (asymmetric content len is enabled). Watch the sync_runner "heap:"
# line after this change to confirm steady-state MQTT is unaffected.
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
# Dynamic TLS record buffers: free the 8 KiB IN / 4 KiB OUT record buffers
# *between* records and reallocate per-record sized to need, instead of holding
# all 12 KiB for the connection's lifetime. This is the targeted fix for the OOM
# death-spiral seen under load: an MQTT write stall -> esp-mqtt auto-reconnect
# churned those 12 KiB through an already-fragmented heap until a 3 KiB malloc
# and the Wi-Fi driver (wifi:m f null) starved. We publish one ~3 KiB event every
# few seconds, so we are heap-bound, not throughput-bound — a great trade.
# The further cert/key-free options (FREE_CA_CERT, ~6 KiB) are gated behind
# MBEDTLS_DYNAMIC_FREE_CONFIG_DATA, which frees the client private key after the
# handshake and is flagged in IDF's own help as problematic for reconnects — a
# real risk on our mutual-TLS link. Held back; revisit only if DYNAMIC_BUFFER
# alone doesn't give enough headroom (watch the sync_runner "heap:" line).
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
# Mozilla CA certificate bundle — lets esp_https_ota validate arbitrary public
# TLS hosts (GitHub + its Fastly CDN across the release/raw 302 redirect) without
# pinning a single cert. Required by the OTA download path (and the Stage-0 spike,
# components/ota_spike). FULL bundle covers the roots GitHub/Fastly chain to.
# Costs ~64 KiB flash; it is in EVERY build once enabled (the firmware is ~1.36 MB
# in a 3 MB partition, so there is ample room).
# NOTE: editing this file alone does NOT re-apply — delete the per-env generated
# sdkconfig (sdkconfig.esp32-s3-devkitm-1) so PlatformIO regenerates it.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y
# Standalone heap leak tracing — DIAGNOSTIC ONLY. It found the leak (a Lua GC
# starvation: sched.run blocks in C between cycles, starving Lua's alloc-driven
# incremental GC, so measurement result tables piled up ~6 KB/min). Fixed with a
# collectgarbage("collect") per sched.run cycle. Re-enable these two lines (the
# `heaptrace start|stop|dump` CLI command compiles back in via #ifdef) if another
# leak ever needs chasing; off by default to reclaim ~17 KiB static .bss.
# CONFIG_HEAP_TRACING_STANDALONE=y
# CONFIG_HEAP_TRACING_STACK_DEPTH=4
