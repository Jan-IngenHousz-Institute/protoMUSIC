# Ambyte BLE provisioning environment
# Copy this file to `.env` and fill in real values.
# Auto-loaded by docs/ambyte_prov.py. Values here are used only when neither
# a CLI flag nor a shell env var is set.
# `.env` is gitignored.

AMBYTE_SSID=YOUR_WIFI_SSID
AMBYTE_PASSWORD=YOUR_WIFI_PASSWORD

AMBYTE_MQTT_URI=mqtts://XXXXXXXXXXXX-ats.iot.REGION.amazonaws.com:8883
AMBYTE_CLIENT_ID=your_thing_name
AMBYTE_TOPIC_ROOT=experiment/data_ingest/v1/<experiment-uuid>/multispeq/v1.0/<thing-name>/test_server
AMBYTE_DEVICE_ID=00:00:00:00

AMBYTE_PROTOCOL_ID=3517
AMBYTE_DEVICE_NAME=AmbyteOnAir
AMBYTE_DEVICE_VERSION=1
AMBYTE_DEVICE_FIRMWARE=1
AMBYTE_FIRMWARE_VERSION=1

AMBYTE_CA_CERT=device_certs/AmazonRootCA1.pem
AMBYTE_DEV_CERT=device_certs/<thing>-certificate.pem.crt
AMBYTE_DEV_KEY=device_certs/<thing>-private.pem.key
