# Ambyte BLE provisioning environment
# Copy this file to `.env` and fill in real values.
# Auto-loaded by docs/ambyte_prov.py and docs/mqtt_tls_test_client.py.
# Values here are used only when neither a CLI flag nor a shell env var is set.
# `.env` is gitignored.

AMBYTE_SSID=YOUR_WIFI_SSID
AMBYTE_PASSWORD=YOUR_WIFI_PASSWORD

AMBYTE_MQTT_URI=mqtts://XXXXXXXXXXXX-ats.iot.REGION.amazonaws.com:8883
# AMBYTE_CLIENT_ID / AMBYTE_TOPIC_ROOT: the literal token {MAC} is expanded by the
# firmware at boot to this board's STA MAC (e.g. AMBYTE10:00:3B:72:22:44), so a
# single .env gives every board a unique MQTT identity. Omit {MAC} to use a fixed
# value (then it's typically the thing name). Either way the AWS IoT policy must
# permit the resulting client id + topic (policies often pin them to the thing name).
# AMBYTE_CLIENT_ID=AMBYTE{MAC}
AMBYTE_TOPIC_ROOT=experiment/data_ingest/v1/<experiment-uuid>/multispeq/v1.0/AMBYTE{MAC}
AMBYTE_DEVICE_ID=00:00:00:00

# Stage-2 inbound command channel (optional). FULL authorized topics — the device
# SUBSCRIBES to AMBYTE_COMMAND_TOPIC and PUBLISHES replies to AMBYTE_STATUS_TOPIC.
# Independent of AMBYTE_TOPIC_ROOT, and typically use the Thing name (not {MAC}).
# The AWS IoT policy must grant Subscribe on the command topic + Publish on the
# status topic. docs/stage2_command_test.py reads these same two vars.
# AMBYTE_COMMAND_TOPIC=experiment/data_ingest/v1/<uuid>/multispeq/v1.0/<thingName>/1234
# AMBYTE_STATUS_TOPIC=experiment/data_ingest/v1/<uuid>/multispeq/v1.0/<thingName>/1234

AMBYTE_PROTOCOL_ID=3517
AMBYTE_DEVICE_NAME=AmbyteOnAir
AMBYTE_DEVICE_VERSION=1
AMBYTE_DEVICE_FIRMWARE=1
AMBYTE_FIRMWARE_VERSION=1
# Optional IANA timezone name, echoed verbatim in the MQTT envelope so the
# cloud pipeline derives local-time columns (measurement_time_local).
# AMBYTE_TIMEZONE=Europe/Amsterdam

# Cert bundle — a subdirectory under device_certs/. Scripts auto-discover the
# CA, device cert, and device key inside. If only one subfolder exists it's
# picked automatically; with multiple you can set this explicitly or let the
# scripts prompt interactively.
AMBYTE_CERT_BUNDLE=your_thing_name

# Optional explicit overrides (skip bundle auto-discovery for these slots):
# AMBYTE_CA_CERT=device_certs/<bundle>/AmazonRootCA1.pem
# AMBYTE_DEV_CERT=device_certs/<bundle>/<hash>-certificate.pem.crt
# AMBYTE_DEV_KEY=device_certs/<bundle>/<hash>-private.pem.key
