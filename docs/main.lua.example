-- Runs a fluorescence trace on every connected AMBIT every 30 seconds and
-- stores the returned arrays (leaf_temp, fluor, fluoRef) to the local DB. The
-- background sync_runner (period 10 s) publishes the stored arrays over MQTT on
-- its own cadence — this script only does run + store.
--
-- Trace (3 segments, type-2 / no-IR, like the notebook's gen_cmd_arr_line):
--   10 points @ 10 Hz, actinic 0    (dark baseline)
--   10 points @ 10 Hz, actinic 255  (full actinic)
--   10 points @ 10 Hz, actinic 0    (relaxation)
--
-- "Every AMBIT": each round pings UART channels 0..3 and runs only on the ones
-- that answer (device.uart_ping wakes the AMBIT; ~2 s timeout on an empty
-- channel). Pinging first matters — running blind on an empty channel would
-- block for the whole run timeout.
--
-- Copy this file to the SD card root as `main.lua` (firmware loads
-- /sdcard/main.lua at boot — see components/lua_runner).

local PERIOD_MS    = 30000   -- delay between rounds
local NUM_CHANNELS = 4       -- AMBIT UART channels 0..3

local trace = {
    { pulses = 10, freq = 10, actinic = 0   },
    { pulses = 10, freq = 10, actinic = 255 },
    { pulses = 10, freq = 10, actinic = 0   },
}

device.log("ambit loop: 3-segment trace on every AMBIT every 30s")

-- No SD-state check needed in the script: the firmware stops this task on
-- card removal and restarts it on reinsertion. (device.sd_ready() is still
-- available if you want to gate something on it from Lua.)
while true do
    local ran = 0
    for ch = 0, NUM_CHANNELS - 1 do
        if device.uart_ping(ch) then
            local r, err = ambit.run(ch, trace, { store = true, timeout_ms = 30000 })
            if r then
                ran = ran + 1
                device.log(string.format("ch%d: %d points, stored %d arrays",
                           ch, r.points, r.stored or 0))
            else
                device.log(string.format("ch%d: run failed: %s", ch, err or "unknown"))
            end
        end
    end
    if ran == 0 then
        device.log("no AMBIT responded on any channel")
    end
    device.sleep_ms(PERIOD_MS)
end



