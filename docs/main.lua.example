-- Reads the BME280 environment 10 times, stores every reading to the local
-- DB, then switches on a 100% / 10 kHz PWM on GPIO4.
--
-- Each reading stores temperature, humidity and pressure as three rows sharing
-- one measure_id (so they publish together). One id is allocated per reading
-- with db.next_id() and passed to all three rows — if measure_id is omitted,
-- db.store allocates a *separate* id per row and the grouping is lost.
--
-- The background sync_runner task (period 10 s) drains PENDING rows to MQTT on
-- its own cadence, so this script only does the read + store half. When the
-- loop finishes the script returns; the PWM output stays on.
--
-- Copy this file to the SD card root as `main.lua`. The firmware loads
-- /sdcard/main.lua at boot (see components/lua_runner).

local READS       = 10
local INTERVAL_MS = 1000   -- delay between readings

device.log(string.format("env loop: %d readings, then PWM 100%% @ 10kHz", READS))

for i = 1, READS do
    local env, err = device.read_env()
    if env then
        local id = db.next_id()
        local ok, store_err = db.store({
            { measure_id = id, sensor = "BME280", quantity = "temperature", value = env.temperature_c },
            { measure_id = id, sensor = "BME280", quantity = "humidity",    value = env.humidity_pct  },
            { measure_id = id, sensor = "BME280", quantity = "pressure",    value = env.pressure_pa   },
        })
        if ok then
            device.log(string.format("[%d/%d] id=%d  T=%.2fC  H=%.2f%%  P=%.0fPa",
                       i, READS, id, env.temperature_c, env.humidity_pct, env.pressure_pa))
        else
            device.log(string.format("[%d/%d] store failed: %s", i, READS, store_err or "unknown"))
        end
    else
        device.log(string.format("[%d/%d] read_env failed: %s", i, READS, err or "unknown"))
    end

    if i < READS then
        device.sleep_ms(INTERVAL_MS)
    end
end

-- Switch the PWM on: 100% duty, 10 kHz, GPIO4.
local pwm_msg = device.PWM(100, 10000, true)
device.log("PWM on -> " .. pwm_msg)
